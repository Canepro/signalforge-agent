# Base URL of SignalForge (no trailing slash).
# For long-lived runners, use the ACA endpoint.
SIGNALFORGE_BASE_URL=https://signalforge.canepro.me
# Local-only override example:
# SIGNALFORGE_BASE_URL=http://host.docker.internal:3000
SIGNALFORGE_AGENT_INSTANCE_ID=container-runner-1
SIGNALFORGE_POLL_INTERVAL_MS=30000
SIGNALFORGE_MAX_BACKOFF_MS=300000
SIGNALFORGE_JOBS_WAIT_SECONDS=20
