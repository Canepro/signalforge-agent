# Base URL of SignalForge (no trailing slash). SIGNALFORGE_URL is also accepted.
# For long-lived agents, use the ACA endpoint and avoid legacy *.vercel.app aliases.
SIGNALFORGE_BASE_URL=https://signalforge.canepro.me

# Do not place SIGNALFORGE_AGENT_TOKEN in this file for the service path.
# The installer stores the token separately and the service loads it via
# SIGNALFORGE_AGENT_TOKEN_FILE.

# Stable opaque id for this machine/process
SIGNALFORGE_AGENT_INSTANCE_ID=host-001-agent-1

# Root of signalforge-collectors checkout (must contain the collector scripts)
SIGNALFORGE_COLLECTORS_DIR=/absolute/path/to/signalforge-collectors

# Optional writable work directory for emitted artifacts and temp files.
# SIGNALFORGE_AGENT_WORKDIR=/var/lib/signalforge-agent/work

# Optional non-default kubectl path for Kubernetes jobs
# SIGNALFORGE_KUBECTL_BIN=/usr/local/bin/kubectl

# Optional explicit kubeconfig path for a dedicated Kubernetes-capable runner.
# The installer can copy a repo-local signalforge-agent.kubeconfig into a
# managed target and set this path automatically.
# SIGNALFORGE_KUBECONFIG=/etc/signalforge-agent/kubeconfig

# Backoff after gate/error in run mode (ms)
SIGNALFORGE_POLL_INTERVAL_MS=30000

# Maximum transient-error backoff in run mode (ms)
SIGNALFORGE_MAX_BACKOFF_MS=300000

# Bounded long-poll window for jobs/next in run mode (seconds; max 20)
SIGNALFORGE_JOBS_WAIT_SECONDS=20

# Optional capabilities override. When omitted, the agent derives capabilities from local
# readiness and always includes upload:multipart.
# SIGNALFORGE_AGENT_CAPABILITIES=collect:linux-audit-log,upload:multipart

# Legacy fallback collector-side inputs for non-Linux families. Prefer typed source defaults
# and per-job collection_scope from SignalForge instead of pinning these on the host.
# SIGNALFORGE_CONTAINER_REF=payments-api
# SIGNALFORGE_CONTAINER_RUNTIME=podman
# SIGNALFORGE_KUBERNETES_CONTEXT=prod-eu-1
# SIGNALFORGE_KUBERNETES_SCOPE=cluster
# SIGNALFORGE_KUBERNETES_NAMESPACE=payments
# SIGNALFORGE_KUBERNETES_CLUSTER_NAME=prod-cluster
# SIGNALFORGE_KUBERNETES_PROVIDER=aks

# Mid-job lease heartbeats while collecting / before upload (ms; min 1000)
SIGNALFORGE_AGENT_LEASE_HEARTBEAT_MS=45000
