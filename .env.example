# Base URL of SignalForge (no trailing slash).
# For long-lived agents, use the ACA endpoint and avoid legacy *.vercel.app aliases.
SIGNALFORGE_BASE_URL=https://signalforge.canepro.me
# Local dev override example:
# SIGNALFORGE_BASE_URL=http://localhost:3000
# Legacy compatibility alias:
# SIGNALFORGE_URL=https://signalforge.canepro.me

# Enrollment token from POST /api/agent/registrations (one source only)
SIGNALFORGE_AGENT_TOKEN=
# Or store the token in a root-controlled file:
# SIGNALFORGE_AGENT_TOKEN_FILE=/etc/signalforge-agent/token

# Stable opaque id for this agent process (claim/start/fail/artifact + lease extension)
SIGNALFORGE_AGENT_INSTANCE_ID=host-001

# Root of signalforge-collectors checkout (must contain first-audit.sh)
SIGNALFORGE_COLLECTORS_DIR=/path/to/signalforge-collectors

# Optional non-default kubectl path for Kubernetes jobs
# SIGNALFORGE_KUBECTL_BIN=/usr/local/bin/kubectl

# Optional explicit kubeconfig path for hardened Kubernetes-capable runners
# SIGNALFORGE_KUBECONFIG=/etc/signalforge-agent/kubeconfig

# Poll interval for `run` mode (ms)
SIGNALFORGE_POLL_INTERVAL_MS=30000

# Maximum transient-error backoff for `run` mode (ms)
# SIGNALFORGE_MAX_BACKOFF_MS=300000

# Mid-job lease heartbeats while collecting / before upload (ms, min 1000)
# SIGNALFORGE_AGENT_LEASE_HEARTBEAT_MS=45000

# Optional: skip collector; upload this file instead (tests / air-gapped)
# SIGNALFORGE_AGENT_ARTIFACT_FILE=/path/to/audit.log
